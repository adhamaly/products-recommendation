datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id              Int         @id @default(autoincrement())
  name            String
  category        String
  area            String
  orders          OrderItem[]
  createdAt       DateTime    @default(now())
  quantityInStock Int?

  @@index(fields: [area, category])
}

model Order {
  id         Int         @id @default(autoincrement())
  customerId Int
  items      OrderItem[]
  createdAt  DateTime    @default(now())
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  role     UserRole
  fcmToken String?
}

enum UserRole {
  ADMIN
  USER
}
